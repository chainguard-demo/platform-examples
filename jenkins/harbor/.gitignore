# Terraform local state and provider plugin cache.
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan
terraform/terraform.tfvars

# Rendered manifests / values (regenerated by deploy.sh from .template files).
cg/manifests/deploy-ingress-nginx.yaml
cg/helm/values.yaml

# Pull-token cache (mirrors the upstream tutorial's convention).
.pull-token
